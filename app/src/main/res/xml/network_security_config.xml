<?xml version="1.0" encoding="utf-8"?>
<!--
    Production: cleartext traffic disabled by default. The release build
    must use HTTPS (see API_BASE_URL in build.gradle.kts).

    Debug-only overrides (cleartext for emulator / LAN dev servers) live in
    src/debug/res/xml/network_security_config.xml so they NEVER ship in
    release builds.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>

